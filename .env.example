# App
NODE_ENV=development
PORT=3000
SELF_URL=http://localhost:8080
ALLOWED_CORS_ORIGIN=http://localhost:8080
SESSION_SECRET=replace-with-at-least-32-random-characters

# Client and dev proxy
VITE_API_BASE_URL=/api
API_PROXY_TARGET=http://localhost:3000

# Database
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/teamvault?sslmode=disable
DATABASE_POOL_SIZE=10

# Ideavibes auth. Use the provisioned production values for hosted deployments.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_alex-vtdc-teamvault-example
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email. Omit both variables to skip email delivery gracefully.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_app_token_example

# S3-compatible object storage
S3_ENDPOINT=https://fly.storage.tigris.dev
S3_REGION=auto
S3_BUCKET=alex-vtdc-teamvault-dev
S3_ACCESS_KEY_ID=tigris_access_key_id
S3_SECRET_ACCESS_KEY=tigris_secret_access_key
S3_FORCE_PATH_STYLE=false
